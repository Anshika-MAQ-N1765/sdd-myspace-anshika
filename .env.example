# Example environment variables for local development and deployment

# Postgres connection string for Prisma
DATABASE_URL=postgresql://postgres:password@localhost:5432/myspace

# Redis connection for read caching and transient store
REDIS_URL=redis://localhost:6379

# Corporate IdP / OIDC runtime configuration
IDP_ISSUER=https://idp.example.com
IDP_CLIENT_ID=your-client-id
IDP_CLIENT_SECRET=your-client-secret

# Next.js auth and session secrets
NEXTAUTH_SECRET=your-nextauth-secret

# Optional feature flags and telemetry endpoints
# FEATURE_FLAGS=leaveWidgetEnabled
# TELEMETRY_URL=https://telemetry.example.com
